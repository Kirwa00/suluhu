{
  "name": "suluhu",
  "version": "1.0.0",
  "private": true,
  "description": "Suluhu Therapy Center — compliant online mental health platform (Eldoret, Kenya)",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "npm run -w @suluhu/api db:generate",
    "db:migrate": "npm run -w @suluhu/api db:migrate",
    "db:seed": "npm run -w @suluhu/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "9.12.0",
    "eslint": "9.12.0",
    "globals": "15.11.0",
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.8.1"
  },
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "nodemon": "^3.1.14"
  }
}
