{
  "name": "@suluhu/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Framework-agnostic domain contracts shared between the API and web app.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "eslint": "9.12.0",
    "rimraf": "6.0.1",
    "typescript": "5.6.3",
    "vitest": "2.1.2"
  }
}
