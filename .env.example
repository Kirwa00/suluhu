# ============================================================================
# Suluhu Therapy Center — environment template
# Copy to `.env` at the repo root. Docker Compose and both apps read from here.
# Never commit a real `.env`. Secrets in production come from a secrets manager.
# ============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
TZ=Africa/Nairobi

# --- API server ------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
# Public base URL of the API (used in emails, webhooks, OpenAPI servers)
API_PUBLIC_URL=http://localhost:4000
# Comma-separated list of allowed web origins for CORS
CORS_ORIGINS=http://localhost:3000

# --- Web app ---------------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=suluhu
POSTGRES_PASSWORD=suluhu_dev_password
POSTGRES_DB=suluhu
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://suluhu:suluhu_dev_password@localhost:5432/suluhu?schema=public

# --- Redis -----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ------------------------------------------------------------
# Generate strong secrets: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# bcrypt cost factor
PASSWORD_SALT_ROUNDS=12

# --- PHI / field-level encryption (Kenya DPA 2019) -------------------------
# 32-byte key, base64-encoded: `openssl rand -base64 32`
PHI_ENCRYPTION_KEY=change-me-base64-32-byte-key-for-phi-aes-256-gcm=

# --- Provider mode ---------------------------------------------------------
# `mock` runs the whole platform locally with no external credentials.
# Switch individual providers to `live` once real keys are supplied.
PROVIDER_MODE=mock

# --- M-Pesa (Safaricom Daraja) ---------------------------------------------
MPESA_MODE=mock
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:4000/api/v1/payments/mpesa/callback

# --- Daily.co video --------------------------------------------------------
VIDEO_MODE=mock
DAILY_API_KEY=
DAILY_DOMAIN=

# --- OpenAI (intake assistant / SOAP drafting) -----------------------------
AI_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Africa's Talking SMS --------------------------------------------------
SMS_MODE=mock
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=SULUHU

# --- Email (SMTP / AWS SES) ------------------------------------------------
EMAIL_MODE=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Suluhu Therapy Center <no-reply@suluhu.co.ke>

# --- Crisis support --------------------------------------------------------
BEFRIENDERS_KENYA_HOTLINE=0800723253
